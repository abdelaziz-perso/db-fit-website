# Apache (Hostinger) — Next.js static export (output: 'export', trailingSlash: true)
# Déployer le contenu de out/ à la racine du site (ce fichier = /.htaccess).
#
# FR = racine `/` (pas /fr/) ; assets Next en /_next/... — pas de basePath / assetPrefix ici.

AddDefaultCharset utf-8

DirectoryIndex index.html

# Pas de listing (évite 403 sur dossiers vides)
Options -Indexes

ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Hôte canonique : www → apex (301). À aligner avec NEXT_PUBLIC_SITE_URL (sans www).
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

  # Forcer HTTPS si l’hébergeur ne le fait pas déjà
  # RewriteCond %{HTTPS} !=on
  # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Assets Next : ne pas les réécrire (même logique que le site « qui marche »)
  RewriteRule ^_next/ - [L]
  RewriteRule ^(fr|en|ar)/_next/ - [L]

  # Fichiers / répertoires réels d’abord
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Anciennes URLs FR à la racine → /fr/slug/
  RewriteRule ^gym-dar-bouazza/?$ /fr/gym-dar-bouazza/ [R=301,L]
  RewriteRule ^salle-de-sport-dar-bouazza/?$ /fr/salle-de-sport-dar-bouazza/ [R=301,L]
  RewriteRule ^fitness-dar-bouazza/?$ /fr/fitness-dar-bouazza/ [R=301,L]
  RewriteRule ^coaching-sportif-dar-bouazza/?$ /fr/coaching-sportif-dar-bouazza/ [R=301,L]
  RewriteRule ^salle-femmes-dar-bouazza/?$ /fr/salle-femmes-dar-bouazza/ [R=301,L]
  RewriteRule ^fitness-mixte-dar-bouazza/?$ /fr/fitness-mixte-dar-bouazza/ [R=301,L]
  RewriteRule ^salle-hommes-dar-bouazza/?$ /fr/salle-hommes-dar-bouazza/ [R=301,L]
  RewriteRule ^abonnement-gym-dar-bouazza/?$ /fr/abonnement-gym-dar-bouazza/ [R=301,L]
  RewriteRule ^programme-musculation-debutant/?$ /fr/programme-musculation-debutant/ [R=301,L]
  RewriteRule ^perdre-poids-rapidement/?$ /fr/perdre-poids-rapidement/ [R=301,L]
  RewriteRule ^exercices-salle-de-sport/?$ /fr/exercices-salle-de-sport/ [R=301,L]
  RewriteRule ^salle-sport-tamaris/?$ /fr/salle-sport-tamaris/ [R=301,L]
  RewriteRule ^gym-casablanca-ouest/?$ /fr/gym-casablanca-ouest/ [R=301,L]

  # Accueil FR : /fr et /fr/ → /
  RewriteRule ^fr/?$ / [R=301,L]

  RewriteRule ^en$ /en/ [R=301,L]
  RewriteRule ^ar$ /ar/ [R=301,L]
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  SetEnvIf Request_URI "^/_next/static/" NEXT_STATIC_ASSET=1
  SetEnvIf Request_URI "^/(fr|en|ar)/_next/static/" NEXT_STATIC_ASSET=1
  Header set Access-Control-Allow-Origin "*" env=NEXT_STATIC_ASSET

  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType text/css .css
  AddType application/javascript .js
  AddType font/woff2 .woff2
</IfModule>
