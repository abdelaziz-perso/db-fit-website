# Next.js export statique — aligné sur nextjs-portfolio-2026 (Hostinger / Apache / LiteSpeed)
#
# _next/static/ sans nom de fichier → 403 souvent NORMAL (pas de listing). Tester une URL .css.

AddDefaultCharset utf-8
DirectoryIndex index.html
Options -Indexes
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteRule ^_next/ - [L]

  # Anciennes URLs françaises à la racine (ancien export sans préfixe /fr/)
  RewriteRule ^gym-dar-bouazza/?$ /fr/gym-dar-bouazza/ [R=301,L]
  RewriteRule ^salle-de-sport-dar-bouazza/?$ /fr/salle-de-sport-dar-bouazza/ [R=301,L]
  RewriteRule ^fitness-dar-bouazza/?$ /fr/fitness-dar-bouazza/ [R=301,L]
  RewriteRule ^coaching-sportif-dar-bouazza/?$ /fr/coaching-sportif-dar-bouazza/ [R=301,L]
  RewriteRule ^salle-femmes-dar-bouazza/?$ /fr/salle-femmes-dar-bouazza/ [R=301,L]
  RewriteRule ^fitness-mixte-dar-bouazza/?$ /fr/fitness-mixte-dar-bouazza/ [R=301,L]
  RewriteRule ^salle-hommes-dar-bouazza/?$ /fr/salle-hommes-dar-bouazza/ [R=301,L]
  RewriteRule ^abonnement-gym-dar-bouazza/?$ /fr/abonnement-gym-dar-bouazza/ [R=301,L]
  RewriteRule ^programme-musculation-debutant/?$ /fr/programme-musculation-debutant/ [R=301,L]
  RewriteRule ^perdre-poids-rapidement/?$ /fr/perdre-poids-rapidement/ [R=301,L]
  RewriteRule ^exercices-salle-de-sport/?$ /fr/exercices-salle-de-sport/ [R=301,L]
  RewriteRule ^salle-sport-tamaris/?$ /fr/salle-sport-tamaris/ [R=301,L]
  RewriteRule ^gym-casablanca-ouest/?$ /fr/gym-casablanca-ouest/ [R=301,L]

  # Canonical host : www → apex (comme le portfolio)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

  # Doublon accueil FR : /fr et /fr/ → / (GET + HEAD pour segment cache Next)
  RewriteCond %{REQUEST_URI} ^/fr/?$ [NC]
  RewriteRule .* / [R=301,L]

  RewriteRule ^en$ /en/ [R=302,L]
  RewriteRule ^ar$ /ar/ [R=302,L]
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  SetEnvIf Request_URI "^/_next/static/" NEXT_STATIC_ASSET=1
  Header set Access-Control-Allow-Origin "*" env=NEXT_STATIC_ASSET

  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType text/css .css
  AddType application/javascript .js
  AddType font/woff2 .woff2
</IfModule>
