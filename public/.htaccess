# Next.js export statique sur Hostinger (Apache / LiteSpeed)
#
# IMPORTANT — test SEO / debug :
#   • https://votredomaine/_next/static/  → 403 est SOUVENT NORMAL (listing de dossier interdit).
#   • Le bon test : ouvrir une URL de fichier, ex. …/chunks/xxxx.css → doit être 200 text/css.
#   Si les .css / .js sont en 403, vérifiez permissions (dossiers 755, fichiers 644) et hPanel.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Laisser passer les fichiers Next sans réécriture (évite qu’une règle
  # catch-all type SPA renvoie du HTML à la place du CSS/JS).
  RewriteRule ^_next/ - [L]

  # Locale par défaut : /fr et /fr/ → / (GET et HEAD). Next.js 16 segment cache en
  # `output: "export"` envoie un HEAD sur l’URL avant prefetch ; un 404 indique souvent
  # que les règles ^fr/… ne matchent pas le chemin réel — REQUEST_URI est plus fiable.
  RewriteCond %{REQUEST_URI} ^/fr/?$ [NC]
  RewriteRule .* / [R=301,L]

  RewriteCond %{REQUEST_URI} ^/fr/(.+)$ [NC]
  RewriteRule .* /%1 [R=301,L]

  # trailingSlash: true — en et ar uniquement (ne pas renvoyer /fr → /fr/)
  RewriteRule ^en$ /en/ [R=302,L]
  RewriteRule ^ar$ /ar/ [R=302,L]
</IfModule>

# Polices préchargées avec crossorigin : certains navigateurs exigent un en-tête CORS
# même en same-origin ; sans lui, les fonts peuvent échouer (page qui paraît “sans style”).
<IfModule mod_headers.c>
  SetEnvIf Request_URI "^/_next/static/" NEXT_STATIC_ASSET=1
  Header set Access-Control-Allow-Origin "*" env=NEXT_STATIC_ASSET

  # Après un déploiement FTP, une vieille index.html en cache pointait vers d’anciens
  # fichiers /_next/static/chunks/*.css (404) → page sans styles. Forcer revalidation du HTML.
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# Types MIME explicites (si le serveur devine mal un fichier statique)
<IfModule mod_mime.c>
  AddType text/css .css
  AddType application/javascript .js
  AddType font/woff2 .woff2
</IfModule>
